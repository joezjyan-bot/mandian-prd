APP_NAME="满点租赁系统"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---------- 数据库 ----------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mandian_rental
DB_USERNAME=root
DB_PASSWORD=

# ---------- 外部对接模式(核心开关)----------
# mock = 模拟模式(演示用,签约/支付/监管锁返回模拟成功)
# real = 真实对接(需团队在 app/Services/External/Real 里填真实通道)
EXTERNAL_MODE=mock

# 申请购买价口径:A=剩余租金+保证金(一期) B=折旧余值(二期)
BUYOUT_FORMULA=A

# ---------- 真实通道配置(real 模式才需,团队填)----------
ESIGN_APP_ID=
ESIGN_APP_SECRET=
ESIGN_BASE_URL=

PAY_MCH_ID=
PAY_API_KEY=
PAY_NOTIFY_URL=

LOCK_API_BASE_URL=
LOCK_API_KEY=

IDVERIFY_APP_ID=
IDVERIFY_APP_SECRET=

# ---------- 中控台(Java)对接 ----------
KONGZHONG_BASE_URL=http://localhost:9000
KONGZHONG_WEBHOOK_SECRET=
