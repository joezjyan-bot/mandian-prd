APP_NAME="满点租赁系统"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# 数据库
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yzz_rental
DB_USERNAME=root
DB_PASSWORD=

# ===== 外部对接模式开关（核心） =====
# mock = 演示模式，签约/支付/监管锁/实名全走模拟，返回成功
# real = 生产模式，走真实对接（需团队填完 Real* 实现）
EXTERNAL_MODE=mock

# 中控台（Java）HTTP API 地址——real 模式下生效
ZHONGKONG_BASE_URL=http://127.0.0.1:9000
ZHONGKONG_API_KEY=

# 支付通道——real 模式下生效
PAYMENT_BASE_URL=
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET=

# 电子签——real 模式下生效
ESIGN_BASE_URL=
ESIGN_APP_ID=
ESIGN_SECRET=
